// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TenantRole {
  OWNER
  ADMIN
  VET
  TECHNICIAN
  RECEPTIONIST
}

enum OnboardingTokenType {
  ADMIN
}

enum PatientSpecies {
  DOG
  CAT
  EQUINE
  BOVINE
  BIRD
  REPTILE
  RABBIT
  OTHER
  ANY   // species-agnostic template — applies to all species
}

enum AgeUnit {
  DAYS
  WEEKS
  MONTHS
  YEARS
}

enum CaseStatus {
  OPEN
  TRIAGED
  ORDERED
  COMPLETED
  CANCELLED
}

enum PatientSex {
  MALE
  FEMALE
  UNKNOWN
}

enum CatalogItemKind {
  TEST
  PACKAGE
}

/// How the lab result value for this test should be interpreted.
/// Nullable — not all tests have structured results yet.
/// NUMERIC: a quantity with a unit (referenceMin/Max live on ReferenceRange, keyed by species).
/// TEXT: a free-text or narrative result (e.g. culture sensitivity report).
/// POSITIVE_NEGATIVE: a qualitative yes/no result (e.g. heartworm antigen).
enum ResultType {
  NUMERIC
  TEXT
  POSITIVE_NEGATIVE
}

enum OrderStatus {
  PENDING          // order placed, waiting for sample
  READY_FOR_PICKUP // clinic flagged sample as ready — courier path only
  COLLECTED        // sample drawn/picked up
  RECEIVED_BY_LAB  // sample physically arrived at lab
  PROCESSING       // analysis underway
  COMPLETED        // results available
  CANCELLED
}

enum OrderPriority {
  ROUTINE
  URGENT
  STAT
}

/// How a single analyte value should be entered and rendered.
enum AnalyteValueType {
  NUMERIC            // number + unit + ref range → auto-flag H/L/N
  TEXT               // single-line string (culture report, microscopy)
  POSITIVE_NEGATIVE  // boolean rendered as Positivo / Negativo
  SELECT             // fixed option list stored in options[]
}

enum ResultReportStatus {
  DRAFT    // lab is entering values — not visible to clinic
  RELEASED // final and immutable — clinic can see it
}

// ---------------------------------------------------------------------------
// Auth / Multi-tenancy
// ---------------------------------------------------------------------------

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  // Contact & clinic details — collected during onboarding clinic-setup step
  address            String?
  city               String?
  email              String?
  phone              String?
  country            String?
  notificationMethod String?  // 'email' | 'sms'
  // Branding — optional, populated via future branding/settings step
  logoUrl            String?  // URL to uploaded logo in storage (never store file data here)
  primaryColor       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  memberships   UserTenantMembership[]
  invitations   TenantInvitation[]
  cases         Case[]
  orders        Order[]

  @@map("tenants")
}

model User {
  id        String   @id // Supabase Auth UUID — never auto-generate, always comes from JWT sub
  email     String   @unique
  firstName String?
  lastName  String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     UserTenantMembership[]
  sentInvitations TenantInvitation[]
  createdCases    Case[]

  @@map("users")
}

model UserTenantMembership {
  userId    String
  tenantId  String
  role      TenantRole
  createdAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])  // composite PK — no surrogate id needed
  @@index([tenantId])
  @@index([userId])
  @@map("user_tenant_memberships")
}

/// Pending invitations sent by clinic owners/admins to bring staff onboard.
/// Token is a signed short-lived value; acceptedAt is set on acceptance.
model TenantInvitation {
  id            String     @id @default(cuid())
  tenantId      String
  email         String
  role          TenantRole
  token         String     @unique
  expiresAt     DateTime
  acceptedAt    DateTime?
  invitedByUserId String

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy  User   @relation(fields: [invitedByUserId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@map("tenant_invitations")
}

/// Onboarding tokens created by Biomet to invite clinic admins.
/// Each token is single-use and expires after 7 days.
/// On completion, the backend creates the Supabase user, Tenant, and ADMIN membership.
model OnboardingToken {
  id              String              @id @default(cuid())
  token           String              @unique
  type            OnboardingTokenType @default(ADMIN)
  clinicName      String
  clinicEmail     String              // contact email for the clinic (Tenant.email)
  biometClinicId  String?             // optional external reference from Biomet
  expiresAt       DateTime
  used            Boolean             @default(false)
  usedAt          DateTime?
  createdAt       DateTime            @default(now())

  @@index([token])
  @@map("onboarding_tokens")
}

// ---------------------------------------------------------------------------
// Cases
// ---------------------------------------------------------------------------

/// A veterinary lab case — the central aggregate of the platform.
/// Patient and owner data are embedded (no separate Patient table for MVP).
/// Order data is embedded as JSON (one order per case for MVP).
/// All case data is scoped to a tenant — cross-tenant access is impossible
/// because every lookup includes tenantId in the WHERE clause.
model Case {
  id        String     @id @default(cuid())
  tenantId  String
  status    CaseStatus @default(OPEN)

  // Patient — embedded (no separate Patient table for MVP)
  patientName        String
  patientSpecies     PatientSpecies
  patientSex         PatientSex?
  patientBreed       String?
  patientDateOfBirth DateTime?    // used when exact DOB is known; age/ageUnit are the fallback
  patientAge         Int?
  patientAgeUnit     AgeUnit?
  patientWeight      Float?       // kilograms

  // Owner
  ownerName  String
  ownerPhone String?

  // Clinical inputs
  symptoms                String?   // free-text symptom description (textarea)
  triageResult            Json?     // AI DDx output: { diagnoses: [...], suggestedCatalogItemIds: [...] }
  suggestedCatalogItemIds String[]  // AI-proposed catalog item IDs (TEST or PACKAGE) — no FK, AI output

  // Order (embedded — one per case for MVP)
  orderNotes  String?
  orderSentAt DateTime?

  // Audit
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy            User                @relation(fields: [createdByUserId], references: [id])
  selectedCatalogItems CaseCatalogItem[]
  order                Order?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([createdByUserId])
  @@map("cases")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

/// Single table for tests and packages, distinguished by kind.
/// Global — owned by the lab, shared across all tenants (clinics).
/// Tests: code, category, turnaroundHours.
/// Packages: description + component tests via CatalogItemComposition.
model CatalogItem {
  id              String          @id @default(cuid())
  kind            CatalogItemKind
  code            String?         @unique // TEST only — lab code (e.g. "CBC"); globally unique
  name            String
  description     String?         // PACKAGE only
  category        String?         // TEST only
  turnaroundHours Int?            // TEST only
  resultType      ResultType?     // TEST only — how to interpret the result value; null = unstructured
  unit            String?         // TEST only — unit of measurement (e.g. "mg/dL", "K/µL"); null = unitless or not applicable
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  components       CatalogItemComposition[] @relation("PackageComponents")
  packages         CatalogItemComposition[] @relation("ComponentPackages")
  caseCatalogItems CaseCatalogItem[]
  resultTemplates  ResultTemplate[]

  @@index([kind])
  @@map("catalog_items")
}

/// Package → constituent TEST items (explicit many-to-many).
model CatalogItemComposition {
  packageId   String
  componentId String

  package   CatalogItem @relation("PackageComponents", fields: [packageId], references: [id], onDelete: Cascade)
  component CatalogItem @relation("ComponentPackages", fields: [componentId], references: [id], onDelete: Cascade)

  @@id([packageId, componentId])
  @@map("catalog_item_compositions")
}

/// Join table: vet-confirmed catalog item selection per case.
/// Using a proper relation (not String[]) for referential integrity and future analytics.
model CaseCatalogItem {
  caseId        String
  catalogItemId String

  case        Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@id([caseId, catalogItemId])
  @@index([caseId])
  @@map("case_catalog_items")
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

/// Monotonic counter used to generate human-readable requisition numbers.
/// Incremented atomically inside the same transaction that creates an Order.
model Counter {
  name  String @id
  value Int    @default(0)

  @@map("counters")
}

/// A lab requisition created when a clinic sends an order.
/// orderedItems is a denormalized JSON snapshot of the catalog items at order
/// time — intentionally not a FK so history stays accurate if catalog changes.
model Order {
  id                  String        @id @default(cuid())
  requisitionNumber   String        @unique  // REQ-2026-000001
  caseId              String        @unique  // one active order per case (MVP)
  tenantId            String
  status              OrderStatus   @default(PENDING)
  priority            OrderPriority @default(ROUTINE)

  /// JSON snapshot: Array<{ catalogItemId, code, name, kind, category?, turnaroundHours? }>
  orderedItems        Json

  clinicNotes         String?   // vet → lab
  labNotes            String?   // internal lab use, not shown to clinic

  // Sample info — filled by lab/clinic staff
  sampleType          String?   // BLOOD | URINE | FECES | SWAB | TISSUE | OTHER
  sampleNotes         String?

  // Timestamps
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  collectedAt         DateTime?
  receivedByLabAt     DateTime?
  processingStartedAt DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?

  case         Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resultReport ResultReport?

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("orders")
}

// ---------------------------------------------------------------------------
// Result Templates (global, Biomet-owned — no tenantId)
// ---------------------------------------------------------------------------

/// Defines the structure of a lab report for a given test + species + age range.
/// ageMinWeeks / ageMaxWeeks are inclusive bounds (null = no limit).
/// createReport picks the most specific matching template for the patient's age;
/// falls back to the age-agnostic template (both null) if no range matches.
/// Global — created and managed by Biomet, shared across all tenants.
model ResultTemplate {
  id            String         @id @default(cuid())
  catalogItemId String
  species       PatientSpecies
  ageMinWeeks   Int?           // null = no lower bound (e.g. adult template)
  ageMaxWeeks   Int?           // null = no upper bound
  title         String         // "Hemograma Canino — 4 Semanas"
  version       Int            @default(1)
  isActive      Boolean        @default(true)
  defaultObservations String?  // prefilled lab note shown at bottom of report

  catalogItem CatalogItem             @relation(fields: [catalogItemId], references: [id])
  sections    ResultTemplateSection[]
  analytes    ResultTemplateAnalyte[]

  @@unique([catalogItemId, species, ageMinWeeks, ageMaxWeeks])
  @@map("result_templates")
}

/// Named group of analytes within a template (e.g. "Serie Roja", "Examen Macroscópico").
model ResultTemplateSection {
  id         String @id @default(cuid())
  templateId String
  name       String
  sortOrder  Int

  template ResultTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  analytes ResultTemplateAnalyte[]

  @@map("result_template_sections")
}

/// One row in a result template — defines what the lab tech fills in.
/// referenceRange JSON shape for MVP: { min?: number, max?: number, displayText: string }
/// Deferred: tiered ranges, age-specific, sex-specific.
model ResultTemplateAnalyte {
  id         String           @id @default(cuid())
  templateId String
  sectionId  String?          // null = template has no sections
  code       String           // stable semantic key: "WBC", "HGB" — AI + machine import anchor
  name       String           // display name: "Recuento total de leucocitos (WBC)"
  technique  String?          // "Impedancia eléctrica"
  valueType  AnalyteValueType
  unit       String?          // "10^3/µL" — null for qualitative analytes
  options    String[]         // SELECT only — valid option values
  sortOrder  Int
  isHeader   Boolean          @default(false) // bold label row — no value input, no flag
  formula    String?          // e.g. "([HCT]*10)/[RBC]" — computed on frontend, read-only input

  /// MVP shape: { min?: number, max?: number, displayText: string }
  /// Extend later with: { tiers: [{label, max}], ageMinMonths, ageMaxMonths, sex }
  referenceRange Json?

  template       ResultTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section        ResultTemplateSection? @relation(fields: [sectionId], references: [id])
  reportAnalytes ResultReportAnalyte[]

  @@map("result_template_analytes")
}

// ---------------------------------------------------------------------------
// Result Reports (tenant-scoped, one per Order)
// ---------------------------------------------------------------------------

/// The actual filled lab result for an order.
/// Created from a ResultTemplate — one report per order for MVP.
/// DRAFT while the lab is entering values; RELEASED is final and visible to the clinic.
model ResultReport {
  id         String             @id @default(cuid())
  orderId    String             @unique // one structured report per order
  caseId     String             // denormalized — fast case-scoped queries without Order join
  tenantId   String             // denormalized — fast tenant scoping
  templateId String             // soft reference — no FK so old reports survive template changes

  status       ResultReportStatus @default(DRAFT)
  observations String?           // lab's free-text note (maps to "Observaciones" on real reports)

  // Professional footer — filled when releasing the report
  processedByName        String?
  processedByRole        String?
  processedByCredentials String?  // e.g. "Universidad Santiago de Cali"
  approvedByName         String?
  approvedByRole         String?
  approvedByCredentials  String?  // e.g. "Universidad del Valle\nRegistro No.: 767658"
  signatureUrl           String?  // approver signature image URL

  // Machine import hook — store raw analyzer payload for audit; mapping deferred
  rawPayload Json?

  // PDF export — generated from structured data on release; not source of truth
  pdfUrl String?

  releasedAt       DateTime?
  releasedByUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order    Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  analytes ResultReportAnalyte[]

  @@index([caseId])
  @@index([tenantId, status])
  @@map("result_reports")
}

/// One filled analyte row within a result report.
/// All display fields are denormalized snapshots so released results are stable
/// even if the source template is later edited.
model ResultReportAnalyte {
  id                String           @id @default(cuid())
  reportId          String
  templateAnalyteId String?          // null when row comes from machine import with no template match

  // Snapshot fields — copied from template at report creation time
  code        String           // "WBC" — the AI and cross-visit query anchor
  name        String
  technique   String?
  unit        String?
  valueType   AnalyteValueType
  sectionName String?          // denormalized from section — render without extra joins
  sortOrder   Int
  isHeader    Boolean          @default(false)
  formula     String?          // snapshot of formula — frontend uses this to auto-compute value

  // Typed value — exactly one is populated per non-header row
  numericValue  Float?
  textValue     String?
  booleanValue  Boolean?       // POSITIVE_NEGATIVE
  selectValue   String?        // SELECT

  // Semantic fields — computed on release and then frozen with the report
  // flag: "H" (High) | "L" (Low) | "N" (Normal) | null (non-numeric or no ref range)
  flag              String?
  referenceSnapshot Json?      // snapshot of referenceRange at release time

  report          ResultReport           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  templateAnalyte ResultTemplateAnalyte? @relation(fields: [templateAnalyteId], references: [id])

  @@index([reportId])
  @@map("result_report_analytes")
}