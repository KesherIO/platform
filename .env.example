# Supabase — get these from your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret   # Settings > API > JWT Secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Settings > API > service_role (keep secret — server only)

# Supabase Postgres connection string — Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# App
PORT=3000
NODE_ENV=development